generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  assignee  String
  status    String
  priority  String
  dueDate   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}