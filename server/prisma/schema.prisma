generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  status      String
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  assignee  String
  status    String
  priority  String
  dueDate   String
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  entity    String
  entityId  Int?
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role String @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
